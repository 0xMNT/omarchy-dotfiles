# Ignore everything by default
*

# Unignore dotfiles we explicitly track
!README.md
!.bashrc
!.gitignore
!.config/

# Track everything in .config
!.config/*/
!.config/**

# Private browser profiles (passwords, cookies, session data)
.config/mozilla/
.config/chromium/

# Binary/runtime data (machine-specific, not portable)
.config/dconf/
.config/pulse/

# App session/cache data
.config/spotify/

# Runtime dbus socket info (machine-specific hash in filename)
.config/fcitx/dbus/
.config/ibus/bus/

# Cached/generated data (recreated at runtime or by omarchy)
.config/fcitx5/conf/cached_layouts
.config/omarchy/backgrounds/
.config/omarchy/current/
