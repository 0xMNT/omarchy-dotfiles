#!/bin/bash

CARD="alsa_card.pci-0000_00_1f.3-platform-skl_hda_dsp_generic"
HEADPHONES="HiFi (HDMI1, HDMI2, HDMI3, Headphones, Mic1, Mic2)"
SPEAKER="HiFi (HDMI1, HDMI2, HDMI3, Mic1, Mic2, Speaker)"

current=$(pactl list cards | grep -A 100 "Name: $CARD" | grep -m1 "Active Profile" | cut -d: -f2- | xargs)

if [[ "$current" == "$HEADPHONES" ]]; then
    pactl set-card-profile "$CARD" "$SPEAKER"
    notify-send "Audio" "Switched to Speaker" --icon=audio-speakers
else
    pactl set-card-profile "$CARD" "$HEADPHONES"
    notify-send "Audio" "Switched to Headphones" --icon=audio-headphones
fi
